# Backend environment variables
# Copy this file to .env and fill in the values before running locally.

APP_VERSION=0.1.0
# Use postgresql+asyncpg:// scheme for the async SQLAlchemy engine (runtime).
# Alembic migrations strip the "+asyncpg" part automatically and use psycopg2.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medcoolteste
SECRET_KEY=change-me-in-production
DEBUG=true
# JWT token expiration in minutes (default: 60)
JWT_EXPIRES_MINUTES=60
# Seconds without a heartbeat before a professional is considered offline (default: 30)
PRESENCE_TIMEOUT_SECONDS=30
# Maximum number of professionals to send offers to per consult request (default: 5)
MATCH_OFFER_BATCH_SIZE=5
# Platform fee percentage taken from each payment (default: 20 for 20%)
PLATFORM_FEE_PERCENT=20

# ── Pagar.me payment gateway (F4 Part 2) ─────────────────────────────────────
# Secret key from your Pagar.me dashboard (Settings > API Keys).
PAGARME_API_KEY=
# Base URL for the Pagar.me v5 API (default: https://api.pagar.me/core/v5).
PAGARME_BASE_URL=https://api.pagar.me/core/v5
# Webhook signing secret (Settings > Webhooks in the Pagar.me dashboard).
# Leave empty to disable signature verification during local development.
PAGARME_WEBHOOK_SECRET=
# Recipient ID for the platform account in Pagar.me (re_xxxxxxxxxxxx).
# Used as the platform-side recipient in split payment rules.
PAGARME_PLATFORM_RECIPIENT_ID=

# ── Cancellation & No-Show Policy (F4 Part 3) ────────────────────────────────
# Hours before the scheduled appointment that allow a full refund (default: 24).
CANCELLATION_MIN_HOURS_FULL_REFUND=24
# Percentage of the payment retained by the platform on late cancellation (default: 50).
CANCELLATION_LATE_FEE_PERCENT=50
# Percentage of the payment refunded to the patient on no-show (default: 0).
CANCELLATION_NO_SHOW_REFUND_PERCENT=0
# Minutes after the scheduled time before a no-show can be registered (default: 15).
CANCELLATION_NO_SHOW_GRACE_MINUTES=15
