# Backend environment variables
# Copy this file to .env and fill in the values before running locally.

APP_VERSION=0.1.0
# Use postgresql+asyncpg:// scheme for the async SQLAlchemy engine (runtime).
# Alembic migrations strip the "+asyncpg" part automatically and use psycopg2.
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medcoolteste
SECRET_KEY=change-me-in-production
DEBUG=true
# JWT token expiration in minutes (default: 60)
JWT_EXPIRES_MINUTES=60
# Seconds without a heartbeat before a professional is considered offline (default: 30)
PRESENCE_TIMEOUT_SECONDS=30
# Maximum number of professionals to send offers to per consult request (default: 5)
MATCH_OFFER_BATCH_SIZE=5
